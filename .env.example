# PostgreSQL
POSTGRES_DB=agentdb
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Ollama
OLLAMA_PORT=11434
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# OpenAI / BigModel compatible API
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=REPLACE_WITH_YOUR_API_KEY
OPENAI_CHAT_MODEL=glm-4

# Chat orchestrator
CHAT_ORCHESTRATOR=classic
CHAT_AGENT_ENABLED=true
CHAT_TOOL_CALLING_ENABLED=true
CHAT_TOOL_CALLING_OPENAI_ONLY=true
CHAT_MAX_TOOL_ROUNDS=3

# RAG embedding config
RAG_EMBED_PROVIDER=openai
RAG_EMBED_MODEL=embedding-2
RAG_EMBED_DIM=1024

# RAG retrieval and context strategy
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=120
RAG_CHUNK_MIN_SIZE=120
RAG_RECALL_TOPK=20
RAG_FINAL_TOPK=5
RAG_MIN_SCORE=0.35
RAG_CITATION_MAX_CHARS=50
RAG_CONTEXT_MAX_CHARS=2600
RAG_CONTEXT_CHUNK_MAX_CHARS=700
RAG_MIN_EVIDENCE_COUNT=1

# Memory
MEMORY_MAX_HISTORY_MESSAGES=50
MEMORY_HISTORY_TTL_HOURS=168
MEMORY_DIRECT_HISTORY_MESSAGES=8

# MCP
MCP_BASE_URL=http://localhost:8090
